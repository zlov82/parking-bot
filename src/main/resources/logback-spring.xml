<?xml version="1.0" encoding="UTF-8"?>
<configuration scan="true">

    <!-- ===== Имя приложения ===== -->
    <springProperty scope="context"
                    name="APP_NAME"
                    source="spring.application.name"
                    defaultValue="application"/>

    <!-- ===== Уровень логов из application.yml ===== -->
    <springProperty scope="context"
                    name="APP_LOG_LEVEL"
                    source="logging.level.ru.parking.parking_bot"
                    defaultValue="INFO"/>

    <!-- ===== Путь логов из ENV (docker-compose) ===== -->
    <!-- Если LOG_PATH не задан → logs -->
    <property name="LOG_PATH" value="${LOG_PATH:-logs}"/>

    <property name="LOG_FILE" value="${LOG_PATH}/${APP_NAME}.log"/>

    <!-- ===== Формат ===== -->
    <property name="LOG_PATTERN"
              value="%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n"/>

    <!-- ===== Console ===== -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>${LOG_PATTERN}</pattern>
        </encoder>
    </appender>

    <!-- ===== File (rolling) ===== -->
    <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_FILE}</file>

        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <fileNamePattern>${LOG_PATH}/${APP_NAME}.%d{yyyy-MM-dd}.%i.log</fileNamePattern>

            <timeBasedFileNamingAndTriggeringPolicy
                    class="ch.qos.logback.core.rolling.SizeAndTimeBasedFNATP">
                <maxFileSize>50MB</maxFileSize>
            </timeBasedFileNamingAndTriggeringPolicy>

            <maxHistory>30</maxHistory>
            <totalSizeCap>2GB</totalSizeCap>
        </rollingPolicy>

        <encoder>
            <pattern>${LOG_PATTERN}</pattern>
        </encoder>
    </appender>

    <!-- ===== Root ===== -->
    <root level="INFO">
        <appender-ref ref="CONSOLE"/>
        <appender-ref ref="FILE"/>
    </root>

    <!-- ===== Уровень из application.yml ===== -->
    <logger name="ru.parking.parking_bot" level="${APP_LOG_LEVEL}"/>
    <logger name="org.springframework" level="INFO"/>
    <logger name="org.hibernate" level="WARN"/>

</configuration>